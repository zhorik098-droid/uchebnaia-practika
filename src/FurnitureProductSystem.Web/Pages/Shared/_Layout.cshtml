<!doctype html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Furniture Product System</title>
    <link rel="icon" type="image/x-icon" href="~/appicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="nav">
        <a class="brand" asp-page="/Index">
            <img src="~/img/logo.png" alt="Logo" />
            <span>Продукция – мебельная компания</span>
        </a>
        <nav class="nav-links">
            <a asp-page="/Products/Index">Продукция</a>
        </nav>
    </header>

    <main class="container">
        <partial name="_AlertsPartial" />
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>